{
  "compilerOptions": {
    /* Core Setup */
    "target": "ES2020",
    "module": "commonjs",
      "moduleResolution": "node",


    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Node compatibility */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,

    /* Dev Experience */
    "sourceMap": true,
     "types": ["node"],
         "ignoreDeprecations": "6.0"

  },
    "exclude": ["node_modules", "drizzle", "drizzle.config.ts"]

}