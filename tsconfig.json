{
  "compilerOptions": {
    /* Core Setup */
    "target": "ES2020",
    "module": "commonjs",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Node compatibility */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,

    /* Dev Experience */
    "sourceMap": true
  },
    "exclude": ["node_modules", "drizzle", "drizzle.config.ts"]

}